# Environment variables (optional)

# OpenWeather Map Tiles API key — enables Precip and Clouds toggles on the weather radar panel.
# https://openweathermap.org/api
# NEXT_PUBLIC_OPENWEATHERMAP_API_KEY=

# Optional Leaflet raster tile URL for traffic (must include {z} {x} {y}; optional {s} for subdomains).
# Supply a provider-specific template; do not commit API secrets in client-side URLs without understanding exposure.
# NEXT_PUBLIC_MAP_TRAFFIC_TILE_URL=
